dplyr::select(name_use, id, trait_value) %>%
tidyr::spread(id, trait_value)
write.csv(processed_down,
paste0("/Users/johanna/Desktop/do-cr-upload-metadata/DOCR-processed-", i, ".csv"),
row.names = FALSE)
}
